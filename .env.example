# install 會自動產生並保留所有秘密。
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-32
NEXDROP_CURSOR_SECRET=replace-with-openssl-rand-hex-32
NEXDROP_IMAGE=ghcr.io/honguan/nexdrop:2.0.0

# 預設使用伺服器區網 IP；也可改成由 DNS A 記錄指向本機的 https://drop.example.com。
NEXDROP_NODE_URL=http://127.0.0.1
NEXDROP_SITE_ADDRESS=:80
# 逗號分隔；留空代表不限制。可填 192.0.2.10,2001:db8::10。
NEXDROP_ALLOWED_IPS=

# 一般設備只需要 NEXDROP_NODE_URL 與 NEXDROP_NODE_KEY。
NEXDROP_NODE_OWNER=admin
NEXDROP_NODE_KEY=replace-with-random-node-key

# Web 管理後台仍使用帳號、密碼與六位數 OTP。
NEXDROP_BOOTSTRAP_ADMIN_USERNAME=admin
NEXDROP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
NEXDROP_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-random-admin-password
NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET=replace-with-base32-totp-secret

NEXDROP_LOGIN_RATE_LIMIT_PER_MINUTE=10
NEXDROP_ADMIN_RATE_LIMIT_PER_MINUTE=30
