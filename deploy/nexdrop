#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$ROOT"

command=${1:-}
if [ -n "$command" ]; then
    shift
fi

ensure_administrator_access() {
    case "$command" in
        credentials)
            [ -r .env ] && return
            if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
                echo "需要管理員權限以讀取既有 .env，現在將透過 sudo 顯示設定。"
                exec sudo -- "$ROOT/deploy/nexdrop" credentials "$@"
            fi
            echo "無法讀取 .env；請確認檔案權限或以 sudo 執行此命令。" >&2
            exit 1
            ;;
        install|configure|configure-secrets|update|status|logs|backup|restore|doctor|cleanup|reset-password|uninstall) ;;
        *) return ;;
    esac
    if docker info >/dev/null 2>&1; then
        return
    fi
    if [ "$(id -u)" -ne 0 ] && command -v sudo >/dev/null 2>&1; then
        echo "需要管理員權限以操作 Docker，現在將透過 sudo 繼續。"
        exec sudo -- "$ROOT/deploy/nexdrop" "$command" "$@"
    fi
    echo "無法連線至 Docker。請確認 Docker 已啟動，或以 sudo 執行此命令。" >&2
    exit 1
}

preserve_env_owner() {
    if [ "$(id -u)" -eq 0 ] && [ -n "${SUDO_USER:-}" ]; then
        chown "$SUDO_USER${SUDO_GID:+:$SUDO_GID}" .env
    fi
    chmod 600 .env
}

env_value() {
    sed -n "s/^$1=//p" .env | tail -n 1
}

set_env_value() {
    key=$1
    value=$2
    temporary=$(mktemp "${TMPDIR:-/tmp}/nexdrop-env.XXXXXX")
    found=false
    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            "$key="*)
                printf '%s=%s\n' "$key" "$value" >>"$temporary"
                found=true
                ;;
            *) printf '%s\n' "$line" >>"$temporary" ;;
        esac
    done <.env
    if [ "$found" = false ]; then
        printf '%s=%s\n' "$key" "$value" >>"$temporary"
    fi
    chmod 600 "$temporary"
    mv "$temporary" .env
    preserve_env_owner
}

random_hex() {
    od -An -N"$1" -tx1 /dev/urandom | tr -d ' \n'
}

random_base32() {
    LC_ALL=C tr -dc 'A-Z2-7' </dev/urandom | head -c "${1:-32}"
}

detect_host_ip() {
    if command -v ip >/dev/null 2>&1; then
        detected=$(ip route get 1.1.1.1 2>/dev/null | awk '{ for (i=1; i<=NF; i++) if ($i=="src") { print $(i+1); exit } }')
        [ -n "$detected" ] && { printf '%s\n' "$detected"; return; }
    fi
    if command -v hostname >/dev/null 2>&1; then
        detected=$(hostname -I 2>/dev/null | awk '{print $1}')
        [ -n "$detected" ] && { printf '%s\n' "$detected"; return; }
    fi
    printf '%s\n' '127.0.0.1'
}

default_node_url() {
    printf 'http://%s\n' "$(detect_host_ip)"
}

site_address_for_node_url() {
    value=$1
    case "$value" in
        http://*) printf '%s\n' ':80' ;;
        https://*) printf '%s\n' "$value" ;;
        *) printf '%s\n' ':80' ;;
    esac
}

regenerate_install_secrets() {
    set_env_value POSTGRES_PASSWORD "$(random_hex 32)"
    set_env_value NEXDROP_CURSOR_SECRET "$(random_hex 32)"
    set_env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD "$(random_hex 24)"
    set_env_value NEXDROP_NODE_KEY "$(random_hex 32)"
    set_env_value NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET "$(random_base32 32)"
    set_env_value NEXDROP_NODE_OWNER "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)"
    node_url=$(default_node_url)
    set_env_value NEXDROP_NODE_URL "$node_url"
    set_env_value NEXDROP_SITE_ADDRESS "$(site_address_for_node_url "$node_url")"
    GENERATED_DEFAULTS=true
}

explain_configuration() {
    cat <<'EOF'
NexDrop 2.0 安裝條件：
  - 一般設備只使用「節點連結 + 節點密鑰」加入，不使用配對碼或 OTP。
  - Web 管理後台使用帳號、密碼與六位數 OTP。
  - 預設節點連結為伺服器 IP 的 HTTP 網址；設定網域時請將 DNS A/AAAA 記錄指向此主機並改為 https://網域。
  - NEXDROP_ALLOWED_IPS 可留空，或使用逗號分隔限制來源 IP。
  - update 會保留 .env、節點密鑰、OTP 與資料卷。
  - 安裝後可執行 ./deploy/nexdrop credentials 再次查看設備匯入資料與 Web 登入資料。
EOF
}

valid_env_password() {
    value=$1
    minimum=$2
    [ "${#value}" -ge "$minimum" ] || return 1
    case "$value" in
        *[!A-Za-z0-9._~!@%+,:/-]*) return 1 ;;
    esac
}

valid_minimum_length() {
    [ "${#1}" -ge "$2" ]
}

validate_env() {
    postgres_password=$(env_value POSTGRES_PASSWORD)
    cursor_secret=$(env_value NEXDROP_CURSOR_SECRET)

    if ! valid_env_password "$postgres_password" 16; then
        echo "POSTGRES_PASSWORD 必須至少 16 字元；可使用英數及 . _ ~ ! @ % + , : / -。若資料庫已初始化，還須同步變更 PostgreSQL nexdrop 帳號密碼。" >&2
        return 1
    fi
    if ! valid_minimum_length "$cursor_secret" 32; then
        echo "NEXDROP_CURSOR_SECRET 必須至少 32 字元；首次安裝請重新執行 ./deploy/nexdrop install" >&2
        return 1
    fi
    validate_public_configuration
}

validate_public_configuration() {
    node_url=$(env_value NEXDROP_NODE_URL)
    site_address=$(env_value NEXDROP_SITE_ADDRESS)
    node_key=$(env_value NEXDROP_NODE_KEY)
    node_owner=$(env_value NEXDROP_NODE_OWNER)
    username=$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)
    email=$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)
    admin_password=$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)
    totp_secret=$(env_value NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET)

    case "$node_url" in http://*|https://*) ;; *) echo "NEXDROP_NODE_URL 必須是 http://IP 或 https://網域" >&2; return 1 ;; esac
    case "$site_address" in :80|:443|http://*|https://*) ;; *) echo "NEXDROP_SITE_ADDRESS 必須是 :80、:443、http://... 或 https://..." >&2; return 1 ;; esac
    if ! valid_minimum_length "$node_key" 32; then
        echo "NEXDROP_NODE_KEY 必須至少 32 字元" >&2
        return 1
    fi
    if [ -z "$node_owner" ]; then
        echo "NEXDROP_NODE_OWNER 不可留空" >&2
        return 1
    fi
    if [ "${#username}" -lt 3 ] || [ "${#username}" -gt 64 ]; then
        echo "NEXDROP_BOOTSTRAP_ADMIN_USERNAME 必須為 3–64 字元" >&2
        return 1
    fi
    case "$email" in *@*) ;; *) echo "NEXDROP_BOOTSTRAP_ADMIN_EMAIL 必須是含 @ 的電子郵件" >&2; return 1 ;; esac
    if ! valid_env_password "$admin_password" 12; then
        echo "NEXDROP_BOOTSTRAP_ADMIN_PASSWORD 必須至少 12 字元" >&2
        return 1
    fi
    if [ "${#totp_secret}" -lt 26 ]; then
        echo "NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET 必須是至少 26 字元的 Base32 密鑰" >&2
        return 1
    fi
}

create_default_env() {
    umask 077
    cp .env.example .env
    preserve_env_owner
    regenerate_install_secrets
}

ensure_env() {
    if [ ! -f .env ]; then
        create_default_env
        CREATED_ENV=true
    fi
    ensure_key() {
        key=$1
        value=$2
        if ! grep -q "^$key=" .env || [ -z "$(env_value "$key")" ]; then
            set_env_value "$key" "$value"
            GENERATED_DEFAULTS=true
            echo "已補上缺少的 $key。"
        fi
    }
    ensure_key NEXDROP_CURSOR_SECRET "$(random_hex 32)"
    ensure_key NEXDROP_NODE_KEY "$(random_hex 32)"
    ensure_key NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET "$(random_base32 32)"
    ensure_key NEXDROP_NODE_OWNER "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)"
    if grep -q '^NEXDROP_DOMAIN=' .env && ! grep -q '^NEXDROP_NODE_URL=' .env; then
        legacy=$(env_value NEXDROP_DOMAIN)
        case "$legacy" in localhost|127.0.0.1) url="http://$legacy" ;; *) url="https://$legacy" ;; esac
        set_env_value NEXDROP_NODE_URL "$url"
        set_env_value NEXDROP_SITE_ADDRESS "$(site_address_for_node_url "$url")"
        GENERATED_DEFAULTS=true
    fi
    ensure_key NEXDROP_NODE_URL "$(default_node_url)"
    ensure_key NEXDROP_SITE_ADDRESS "$(site_address_for_node_url "$(env_value NEXDROP_NODE_URL)")"
    ensure_key NEXDROP_ALLOWED_IPS ""
}

replace_install_placeholders() {
    case "$(env_value POSTGRES_PASSWORD)" in
        change-me|replace-with-openssl-rand-hex-32)
            set_env_value POSTGRES_PASSWORD "$(random_hex 32)"
            GENERATED_DEFAULTS=true
            ;;
    esac
    case "$(env_value NEXDROP_CURSOR_SECRET)" in
        change-me|replace-with-openssl-rand-hex-32)
            set_env_value NEXDROP_CURSOR_SECRET "$(random_hex 32)"
            GENERATED_DEFAULTS=true
            ;;
    esac
    case "$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)" in
        change-me|change-this-password|replace-with-a-random-admin-password)
            set_env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD "$(random_hex 24)"
            GENERATED_DEFAULTS=true
            ;;
    esac
    case "$(env_value NEXDROP_NODE_KEY)" in
        change-me|replace-with-random-node-key)
            set_env_value NEXDROP_NODE_KEY "$(random_hex 32)"
            GENERATED_DEFAULTS=true
            ;;
    esac
    case "$(env_value NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET)" in
        change-me|replace-with-base32-totp-secret)
            set_env_value NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET "$(random_base32 32)"
            GENERATED_DEFAULTS=true
            ;;
    esac
    case "$(env_value NEXDROP_IMAGE)" in
        ghcr.io/honguan/nexdrop:1.*) set_env_value NEXDROP_IMAGE "ghcr.io/honguan/nexdrop:2.0.0" ;;
    esac
}

prompt_value() {
    label=$1
    current=$2
    printf '%s [%s]: ' "$label" "$current" >&2
    IFS= read -r answer || answer=
    printf '%s\n' "${answer:-$current}"
}

prompt_secret() (
    label=$1
    current=$2
    state=
    if [ -t 0 ]; then
        state=$(stty -g)
        trap 'stty "$state"' EXIT HUP INT TERM
        stty -echo
    fi
    printf '%s（留空保留目前值）: ' "$label" >&2
    IFS= read -r answer || answer=
    if [ -n "$state" ]; then
        stty "$state"
        printf '\n' >&2
        trap - EXIT HUP INT TERM
    fi
    printf '%s\n' "${answer:-$current}"
)

edit_all_install_configuration() {
    set_env_value NEXDROP_NODE_URL "$(prompt_value '節點連結（預設 IP；網域請填 https://...）' "$(env_value NEXDROP_NODE_URL)")"
    set_env_value NEXDROP_SITE_ADDRESS "$(site_address_for_node_url "$(env_value NEXDROP_NODE_URL)")"
    set_env_value NEXDROP_ALLOWED_IPS "$(prompt_value '允許來源 IP（逗號分隔，留空不限）' "$(env_value NEXDROP_ALLOWED_IPS)")"
    set_env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME "$(prompt_value '管理員帳號' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)")"
    set_env_value NEXDROP_NODE_OWNER "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)"
    set_env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL "$(prompt_value '管理員電子郵件' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)")"
    set_env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD "$(prompt_secret '管理員密碼' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)")"
    set_env_value POSTGRES_PASSWORD "$(prompt_secret 'PostgreSQL 密碼' "$(env_value POSTGRES_PASSWORD)")"
    set_env_value NEXDROP_CURSOR_SECRET "$(prompt_secret '分頁游標秘密' "$(env_value NEXDROP_CURSOR_SECRET)")"
    set_env_value NEXDROP_NODE_KEY "$(prompt_secret '節點密鑰' "$(env_value NEXDROP_NODE_KEY)")"
}

edit_install_configuration_until_valid() {
    while :; do
        edit_all_install_configuration
        if validate_env; then
            return
        fi
        echo "設定不符合上方條件，請重新輸入。" >&2
    done
}

configure_install() {
    while :; do
        cat <<EOF

已產生安全隨機預設：
  節點連結：$(env_value NEXDROP_NODE_URL)
  管理員帳號：$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)
  管理員電子郵件：$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)
  管理員密碼：$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)
  PostgreSQL 密碼：$(env_value POSTGRES_PASSWORD)
  分頁游標秘密：$(env_value NEXDROP_CURSOR_SECRET)
EOF
        printf '接受預設 [a]、逐項更新全部設定 [e]、重新隨機全部秘密 [r]（預設 a）: '
        IFS= read -r choice || choice=a
        case "${choice:-a}" in
            a|A) break ;;
            e|E) edit_install_configuration_until_valid; break ;;
            r|R)
                regenerate_install_secrets
                ;;
            *) echo "請輸入 a、e 或 r。" ;;
        esac
    done
}

confirm_existing_configuration() {
    while :; do
        cat <<EOF

偵測到既有設定：
  節點連結：$(env_value NEXDROP_NODE_URL)
  管理員帳號：$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)
  管理員電子郵件：$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)
  Bootstrap 初始密碼：$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)（若已重設則失效）
EOF
        printf '沿用設定 [a]、查看全部秘密 [s]，或更新網域／管理員資料 [e]（預設 a）: '
        IFS= read -r choice || choice=a
        case "${choice:-a}" in
            a|A) return ;;
            s|S) show_credentials --show-secrets; return ;;
            e|E)
                set_env_value NEXDROP_NODE_URL "$(prompt_value '節點連結（預設 IP；網域請填 https://...）' "$(env_value NEXDROP_NODE_URL)")"
                set_env_value NEXDROP_SITE_ADDRESS "$(site_address_for_node_url "$(env_value NEXDROP_NODE_URL)")"
                set_env_value NEXDROP_ALLOWED_IPS "$(prompt_value '允許來源 IP（逗號分隔，留空不限）' "$(env_value NEXDROP_ALLOWED_IPS)")"
                set_env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME "$(prompt_value '管理員帳號' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)")"
                set_env_value NEXDROP_NODE_OWNER "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)"
                set_env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL "$(prompt_value '管理員電子郵件' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)")"
                set_env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD "$(prompt_secret 'Bootstrap 管理員密碼' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)")"
                validate_public_configuration
                return
                ;;
            *) echo "請輸入 a、s 或 e。" >&2 ;;
        esac
    done
}

show_credentials() {
    ensure_env
    node_url=$(env_value NEXDROP_NODE_URL)
    node_key=$(env_value NEXDROP_NODE_KEY)
    username=$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)
    email=$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)
    totp_secret=$(env_value NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET)
    otp_code=$(docker compose run --rm --no-deps -T nexdrop totp-code --secret "$totp_secret" 2>/dev/null || printf '%s' '請啟動節點後再取得')
    import_json=$(printf '{"nodeUrl":"%s","nodeKey":"%s"}' "$node_url" "$node_key")
    cat <<EOF
NexDrop 2.0 節點與登入資料（請勿貼到公開位置）：
  節點連結：$node_url
  節點密鑰：$node_key
  一鍵匯入：$import_json

Web 管理後台：
  網址：$node_url
  帳號：$username
  電子郵件：$email
  Bootstrap 初始密碼：$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)
  OTP 設定密鑰：$totp_secret
  目前六位數 OTP：$otp_code
  Authenticator URI：otpauth://totp/NexDrop:$username?secret=$totp_secret&issuer=NexDrop&algorithm=SHA1&digits=6&period=30
  來源 IP 限制：$(env_value NEXDROP_ALLOWED_IPS)
EOF
    if [ "${1:-}" = "--show-secrets" ]; then
        cat <<EOF
  PostgreSQL 密碼：$(env_value POSTGRES_PASSWORD)
  分頁游標秘密：$(env_value NEXDROP_CURSOR_SECRET)
EOF
    fi
}

verify_database_credentials() {
    docker compose up -d --wait --wait-timeout 120 postgres
    if ! docker compose exec -T postgres sh -c 'PGPASSWORD="$POSTGRES_PASSWORD" psql -h 127.0.0.1 -U nexdrop -d nexdrop -tAc "SELECT 1" >/dev/null'; then
        echo "PostgreSQL 密碼與既有資料 volume 不一致。未存資料的新安裝可移除 volume 後重裝；已有資料時請先備份並同步修改 nexdrop 角色密碼。" >&2
        return 1
    fi
}

run_install() {
    non_interactive=false
    if [ "${1:-}" = "--non-interactive" ]; then
        non_interactive=true
        shift
    fi
    if [ "$#" -ne 0 ]; then
        echo "usage: nexdrop install [--non-interactive]" >&2
        exit 2
    fi
    CREATED_ENV=false
    GENERATED_DEFAULTS=false
    ensure_env
    replace_install_placeholders
    explain_configuration
    if { [ "$CREATED_ENV" = true ] || [ "$GENERATED_DEFAULTS" = true ]; } && [ "$non_interactive" = false ]; then
        configure_install
    elif [ "$CREATED_ENV" = false ] && [ "$GENERATED_DEFAULTS" = false ] && [ "$non_interactive" = false ]; then
        confirm_existing_configuration
    elif [ "$CREATED_ENV" = false ] && [ "$GENERATED_DEFAULTS" = false ]; then
        echo "非互動模式沿用既有 .env；如需調整請執行 ./deploy/nexdrop configure。"
    fi
    validate_env
    docker compose config >/dev/null
    docker compose pull nexdrop postgres caddy
    verify_database_credentials
    docker compose up -d --wait --wait-timeout 120
    if [ "$CREATED_ENV" = true ] || [ "$GENERATED_DEFAULTS" = true ]; then
        echo "安裝完成。請立即安全保存以下資料："
        show_credentials
        echo "設定已保存於 .env。之後可執行 ./deploy/nexdrop credentials 再次查看。"
    fi
}

run_update() {
    ensure_env
    validate_env
    version=${1:-}
    if [ "$#" -gt 1 ]; then
        echo "usage: nexdrop update [VERSION]" >&2
        exit 2
    fi
    if [ -z "$version" ]; then
        if ! command -v curl >/dev/null 2>&1; then
            echo "自動查詢最新版需要 curl；請安裝 curl，或執行 ./deploy/nexdrop update X.Y.Z。" >&2
            exit 1
        fi
        version=$(curl -fsSL https://api.github.com/repos/Honguan/NexDrop/releases/latest | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"v\([0-9][0-9.]*\)".*/\1/p' | head -n 1)
        if [ -z "$version" ]; then
            echo "無法取得 NexDrop 最新正式版本；請稍後再試，或執行 ./deploy/nexdrop update X.Y.Z。" >&2
            exit 1
        fi
        echo "偵測到最新正式版本：$version"
    fi
    if ! printf '%s' "$version" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        echo "VERSION 必須使用 X.Y.Z 格式" >&2
        exit 2
    fi

    stamp=$(date -u +%Y%m%dT%H%M%SZ)
    docker compose run --rm nexdrop backup --output "/var/lib/nexdrop/backups/pre-update-$stamp.tar.gz"
    old_image=$(env_value NEXDROP_IMAGE)
    set_env_value NEXDROP_IMAGE "ghcr.io/honguan/nexdrop:$version"
    if ! docker compose config >/dev/null || ! docker compose pull nexdrop postgres caddy || ! docker compose up -d --wait --wait-timeout 120; then
        docker compose stop nexdrop || true
        set_env_value NEXDROP_IMAGE "$old_image"
        echo "更新失敗，已停止 NexDrop 並還原原映像設定。新版 migration 可能已套用，請依發布說明確認相容性，必要時從 /var/lib/nexdrop/backups/pre-update-$stamp.tar.gz 還原後再啟動。" >&2
        exit 1
    fi
    echo "更新完成；.env、PostgreSQL 密碼與 NEXDROP_CURSOR_SECRET 均保持不變。"
}

prompt_yes_no() {
    printf '%s [y/N]: ' "$1"
    IFS= read -r answer || answer=n
    case "$answer" in y|Y) return 0 ;; *) return 1 ;; esac
}

prompt_new_secret() {
    label=$1
    bytes=$2
    current=$3
    value=$(prompt_secret "$label（輸入 r 可重新隨機產生）" "$current")
    if [ "$value" = r ] || [ "$value" = R ]; then
        random_hex "$bytes"
    else
        printf '%s\n' "$value"
    fi
}

run_configure_secrets() {
    if [ "$#" -ne 0 ]; then
        echo "usage: nexdrop configure-secrets" >&2
        exit 2
    fi
    ensure_env
    validate_env
    verify_database_credentials

    if prompt_yes_no "要更新目前管理員登入密碼嗎？"; then
        identifier=$(prompt_value '管理員帳號或電子郵件' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)")
        password=$(prompt_new_secret '新管理員密碼' 24 '')
        if ! valid_minimum_length "$password" 12; then
            echo "管理員密碼必須至少 12 字元。" >&2
            exit 1
        fi
        printf '%s\n' "$password" | docker compose run --rm -T nexdrop reset-password --identifier "$identifier"
        echo "管理員密碼已更新；系統不會把目前密碼寫回 .env，請立即安全保存。"
    fi

    if prompt_yes_no "要更新 PostgreSQL 密碼嗎？"; then
        new_database_password=$(prompt_new_secret '新 PostgreSQL 密碼' 32 "$(env_value POSTGRES_PASSWORD)")
        if ! valid_env_password "$new_database_password" 16; then
            echo "PostgreSQL 密碼必須至少 16 字元，且只能使用安裝條件列出的字元。" >&2
            exit 1
        fi
        if [ "$new_database_password" != "$(env_value POSTGRES_PASSWORD)" ]; then
            printf "ALTER ROLE nexdrop PASSWORD :'new_password';\n" | docker compose exec -T -e "NEXDROP_NEW_PASSWORD=$new_database_password" postgres sh -c 'PGPASSWORD="$POSTGRES_PASSWORD" psql -h 127.0.0.1 -U nexdrop -d nexdrop -v new_password="$NEXDROP_NEW_PASSWORD"'
            set_env_value POSTGRES_PASSWORD "$new_database_password"
            docker compose up -d --wait --wait-timeout 120 postgres nexdrop caddy
            echo "PostgreSQL 密碼已同步更新至資料庫與 .env。"
        fi
    fi

    if prompt_yes_no "要更新分頁游標秘密嗎？（既有游標會立即失效）"; then
        new_cursor_secret=$(prompt_new_secret '新分頁游標秘密' 32 "$(env_value NEXDROP_CURSOR_SECRET)")
        if ! valid_minimum_length "$new_cursor_secret" 32; then
            echo "分頁游標秘密必須至少 32 字元。" >&2
            exit 1
        fi
        set_env_value NEXDROP_CURSOR_SECRET "$new_cursor_secret"
        docker compose up -d --wait --wait-timeout 120 nexdrop caddy
        echo "分頁游標秘密已更新；所有先前游標均已失效。"
    fi
}

ensure_administrator_access "$@"

case "$command" in
    install) run_install "$@" ;;
    configure)
        CREATED_ENV=false
        GENERATED_DEFAULTS=false
        ensure_env
        explain_configuration
        echo "此命令只更新網域與 Bootstrap 管理員資料；既有管理員密碼請使用 reset-password。"
        set_env_value NEXDROP_NODE_URL "$(prompt_value '節點連結（預設 IP；網域請填 https://...）' "$(env_value NEXDROP_NODE_URL)")"
    set_env_value NEXDROP_SITE_ADDRESS "$(site_address_for_node_url "$(env_value NEXDROP_NODE_URL)")"
    set_env_value NEXDROP_ALLOWED_IPS "$(prompt_value '允許來源 IP（逗號分隔，留空不限）' "$(env_value NEXDROP_ALLOWED_IPS)")"
        set_env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME "$(prompt_value 'Bootstrap 管理員帳號' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)")"
        set_env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL "$(prompt_value 'Bootstrap 管理員電子郵件' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)")"
        set_env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD "$(prompt_secret 'Bootstrap 管理員密碼' "$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)")"
        validate_public_configuration
        docker compose config >/dev/null
        docker compose up -d --wait --wait-timeout 120
        echo "設定已更新並套用。既有管理員帳號不會改名；修改既有密碼請使用 reset-password。"
        ;;
    update) run_update "$@" ;;
    configure-secrets) run_configure_secrets "$@" ;;
    credentials)
        if [ "$#" -gt 1 ] || { [ "$#" -eq 1 ] && [ "$1" != "--show-secrets" ]; }; then
            echo "usage: nexdrop credentials [--show-secrets]" >&2
            exit 2
        fi
        show_credentials "${1:-}"
        ;;
    status) docker compose ps ;;
    logs) docker compose logs "$@" ;;
    backup) docker compose run --rm nexdrop backup "$@" ;;
    restore)
        docker compose stop nexdrop
        docker compose run --rm --no-deps nexdrop restore "$@"
        docker compose up -d --wait --wait-timeout 120 nexdrop
        ;;
    doctor)
        ensure_env
        validate_env
        docker compose config >/dev/null
        docker compose run --rm nexdrop doctor
        ;;
    cleanup) docker compose run --rm nexdrop cleanup "$@" ;;
    reset-password) docker compose run --rm -T nexdrop reset-password "$@" ;;
    uninstall)
        if [ "${1:-}" = "--purge" ]; then
            docker compose down --volumes
        else
            docker compose down
        fi
        ;;
    *)
        echo "usage: nexdrop {install|configure|configure-secrets|credentials [--show-secrets]|update [VERSION]|status|logs|backup|restore|cleanup|doctor|reset-password|uninstall}" >&2
        exit 2
        ;;
esac
