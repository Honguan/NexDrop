POSTGRES_PASSWORD=change-me
# NEXDROP_CURSOR_SECRET 由 deploy/nexdrop install 產生；直接使用 Compose 時須自行設定至少 32 字元亂數。
NEXDROP_IMAGE=ghcr.io/honguan/nexdrop:1.0.0
NEXDROP_DOMAIN=localhost
NEXDROP_BOOTSTRAP_ADMIN_USERNAME=admin
NEXDROP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
NEXDROP_BOOTSTRAP_ADMIN_PASSWORD=change-this-password
NEXDROP_LOGIN_RATE_LIMIT_PER_MINUTE=10
NEXDROP_PAIRING_RATE_LIMIT_PER_MINUTE=10
NEXDROP_ADMIN_RATE_LIMIT_PER_MINUTE=30
