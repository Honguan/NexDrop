 show_credentials() {
     ensure_env
+    node_url=$(env_value NEXDROP_NODE_URL)
+    node_key=$(env_value NEXDROP_NODE_KEY)
+    username=$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)
+    email=$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)
+    totp_secret=$(env_value NEXDROP_BOOTSTRAP_ADMIN_TOTP_SECRET)
+    otp_code=$(docker compose run --rm --no-deps -T nexdrop totp-code --secret "$totp_secret" 2>/dev/null || printf '%s' '請啟動節點後再取得')
+    import_json=$(printf '{"nodeUrl":"%s","nodeKey":"%s"}' "$node_url" "$node_key")
     cat <<EOF
-NexDrop 管理員初始登入資料（請勿貼到公開位置）：
-  節點網址：https://$(env_value NEXDROP_DOMAIN)
-  管理員帳號：$(env_value NEXDROP_BOOTSTRAP_ADMIN_USERNAME)
-  管理員電子郵件：$(env_value NEXDROP_BOOTSTRAP_ADMIN_EMAIL)
+NexDrop 2.0 節點與登入資料（請勿貼到公開位置）：
+  節點連結：$node_url
+  節點密鑰：$node_key
+  一鍵匯入：$import_json
+
+Web 管理後台：
+  網址：$node_url
+  帳號：$username
+  電子郵件：$email
   Bootstrap 初始密碼：$(env_value NEXDROP_BOOTSTRAP_ADMIN_PASSWORD)
-  注意：若已透過 Web 或 reset-password 變更密碼，上述初始密碼已失效，系統無法還原目前密碼。
+  OTP 設定密鑰：$totp_secret
+  目前六位數 OTP：$otp_code
+  Authenticator URI：otpauth://totp/NexDrop:$username?secret=$totp_secret&issuer=NexDrop&algorithm=SHA1&digits=6&period=30
+  來源 IP 限制：$(env_value NEXDROP_ALLOWED_IPS)
 EOF
-    if [ "${1:-}" != "--show-secrets" ]; then
-        echo "如需查看 PostgreSQL 密碼與游標秘密，請明確執行 ./deploy/nexdrop credentials --show-secrets。"
-        return
-    fi
-    cat <<EOF
+    if [ "${1:-}" = "--show-secrets" ]; then
+        cat <<EOF
   PostgreSQL 密碼：$(env_value POSTGRES_PASSWORD)
   分頁游標秘密：$(env_value NEXDROP_CURSOR_SECRET)
 EOF
+    fi
 }
 
