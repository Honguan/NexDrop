+            channelDescription: '設備加入與收到新內容通知',
+            importance: Importance.high,
+            priority: Priority.high,
+          ),
+          windows: WindowsNotificationDetails(),
+        ),
+      );
+    } catch (_) {
+      // The in-app banner remains available when the OS rejects notifications.
+    }
+  }
