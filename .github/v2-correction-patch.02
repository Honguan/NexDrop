+String _deviceName(AppController controller, String id) {
+  for (final device in controller.devices) {
+    if (device.id == id) return device.displayName;
+  }
+  return id.length > 8 ? id.substring(0, 8) : id;
+}
+
 String _formatBytes(int value) {
