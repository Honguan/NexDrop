#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$ROOT"

command=${1:-}
if [ -n "$command" ]; then
    shift
fi

case "$command" in
    install)
        docker compose config >/dev/null
        docker compose up -d --build
        ;;
    update)
        stamp=$(date -u +%Y%m%dT%H%M%SZ)
        docker compose run --rm nexdrop backup --output "/var/lib/nexdrop/backups/pre-update-$stamp.tar.gz"
        docker compose pull --ignore-buildable
        docker compose build --pull nexdrop
        docker compose up -d
        ;;
    status)
        docker compose ps
        ;;
    logs)
        docker compose logs "$@"
        ;;
    backup)
        docker compose run --rm nexdrop backup "$@"
        ;;
    restore)
        docker compose stop nexdrop
        docker compose run --rm --no-deps nexdrop restore "$@"
        docker compose up -d nexdrop
        ;;
    doctor)
        docker compose config >/dev/null
        docker compose run --rm nexdrop doctor
        ;;
    cleanup)
        docker compose run --rm nexdrop cleanup "$@"
        ;;
    reset-password)
        docker compose run --rm -T nexdrop reset-password "$@"
        ;;
    uninstall)
        if [ "${1:-}" = "--purge" ]; then
            docker compose down --volumes
        else
            docker compose down
        fi
        ;;
    *)
        echo "usage: nexdrop {install|update|status|logs|backup|restore|cleanup|doctor|reset-password|uninstall}" >&2
        exit 2
        ;;
esac
